<Window x:Class="KeyCapture.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyCapture Settings"
        Width="480" Height="200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Icon="/Resources/app.ico">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Capture Settings"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <CheckBox Grid.Row="1"
                  x:Name="SpecialKeysOnlyCheckBox"
                  Content="Only capture special keys &amp; combos (hide regular typing)"
                  FontSize="13"
                  VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" Height="30"
                    IsDefault="True" Click="OnOkClick" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="30"
                    IsCancel="True" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
