<Window x:Class="KeyCapture.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False">

    <Border x:Name="PART_Container" Opacity="0"
            CornerRadius="6"
            Background="#CC1E1E1E"
            Padding="14,8">
        <TextBlock x:Name="PART_Text"
                   Foreground="White"
                   FontSize="18"
                   FontFamily="Segoe UI Semibold"
                   Text="">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="4"
                                  ShadowDepth="1"
                                  Opacity="0.6"/>
            </TextBlock.Effect>
        </TextBlock>
    </Border>
</Window>
